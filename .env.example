# ─── Database ───────────────────────────────────────────
DB_PASSWORD=shopease_secret

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production-min-512-bits-long!!

# ─── AWS SES (Email) ───────────────────────────────────
# Create an IAM user with SES SendEmail permissions
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SES_REGION=eu-west-1
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# ─── Hubtel SMS ─────────────────────────────────────────
# Get credentials from https://developers.hubtel.com
HUBTEL_CLIENT_ID=your-client-id
HUBTEL_CLIENT_SECRET=your-client-secret
HUBTEL_FROM=ShopEase
